# Cle API Gemini (Google AI Studio), optionnelle. Sans cle, le conseiller IA
# degrade automatiquement vers un plan base sur des regles (pas d'erreur).
# Gratuite a obtenir sur aistudio.google.com (palier gratuit avec quota).
GEMINI_API_KEY=

# Modele utilise pour la generation du plan d'amelioration.
GEMINI_MODEL=gemini-2.5-flash-lite

# Origines autorisees en CORS, separees par des virgules.
# En local: http://localhost:5173
# En prod: https://votre-frontend.vercel.app
CORS_ORIGINS=http://localhost:5173

MAX_UPLOAD_SIZE_MB=5
UPLOAD_DIR=uploads
